# Example environment variables for AgentGate demo
# Copy to .env and fill values for local testing (DO NOT commit real private keys)

# RPC endpoint for ENS (Ethereum) — this is SEPARATE from Arc payments.
# Use Sepolia for hackathon (cheap + fast): https://ethereum-sepolia.publicnode.com
# Must match the network where you registered agentgate.eth (mainnet vs sepolia)
RPC_URL="https://ethereum-sepolia.publicnode.com"

# Private key for demo wallets (use ephemeral test keys only)
#
# Agent identity (can be the buyer or seller depending on the context)
DEMO_PRIVATE_KEY="0x0123456789abcdef..."

# Arc / Circle configuration
ARC_API_KEY=""
CIRCLE_API_KEY=""
ARC_RPC_URL=""

# x402 seller configuration for the provider server
SELLER_ADDRESS="0x0000000000000000000000000000000000000000"
CALL_PRICE="1000"
PORT="3000"
NODE_ENV="development"

# World / AgentKit configuration
WORLD_API_KEY=""
WORLD_RPC_URL=""
FREE_TRIAL_LIMIT="5"

# ENS parent name to use for registration (optional during dev)
ENS_PARENT="agentgate.eth"

# Optional: explicit chain for ENS (sepolia or mainnet). If not set, falls back to detecting from RPC_URL string.
# Recommended for custom RPC endpoints to avoid misclassification.
ENS_CHAIN="sepolia"

# Onchain integration workflow controls
# Keep false unless you intentionally want to send a real Gateway deposit transaction.
RUN_ONCHAIN_DEPOSIT="false"
ONCHAIN_DEPOSIT_AMOUNT="0.01"

# Buyer wallet used by funded x402/onchain smoke checks. Use an ephemeral funded testnet key only.
BUYER_PRIVATE_KEY="0x0123456789abcdef..."

# Live smoke gates. Leave false unless intentionally spending testnet resources.
RUN_LIVE_ENS_SMOKE="false"
RUN_LIVE_X402_SMOKE="false"
ENS_RESOLVER_ADDRESS=""
ENS_SMOKE_LABEL=""
ENS_SMOKE_X402_ENDPOINT="http://localhost:3000/call"
ENS_SMOKE_X402_PRICE="0.001"
AGENTGATE_PROVIDER_URL=""

# Demo runner controls
RUN_DEMO_DISCOVERY="false"
RUN_DEMO_PAID_CALL="false"
DEMO_AGENT_NAME="local.agentgate.eth"
DEMO_X402_PRICE="0.001"
DEMO_AGENTKIT_HEADER=""
AGENTKIT_HEADER=""
DEMO_FREE_CALLS="2"
ANVIL_RPC_URL="http://127.0.0.1:8545"

# Circle Gateway API URL (optional, defaults to testnet)
CIRCLE_API_URL=
